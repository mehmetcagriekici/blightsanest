# BlightSanest — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.

# CoinGecko API key
# Get yours at https://www.coingecko.com/en/api
COIN_GECKO_KEY=your_coingecko_api_key_here

# RabbitMQ connection URL
# Format: amqp://user:password@host:port/vhost
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# How long before a cached crypto entry is considered stale and removed (e.g. 1h, 30m)
CACHE_INTERVAL=1h

# Prefetch count for AMQP QoS — controls how many messages a subscriber receives at once
SUBSCRIBER_PREFETCH=10

# PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://user:password@localhost:5432/blightsanest?sslmode=disable

# FastAPI URL for the semantic search service — must match the value in docker-compose.yml
SEMANTIC_API_URL=http://localhost:8000
